{
  "manifest_version": 3,
  "name": "Keye Deal Context",
  "version": "1.0.0",
  "description": "AI-powered deal context for Google Calendar events",
  "permissions": [
    "sidePanel",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://calendar.google.com/*",
    "https://gmail-integration-calendar.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://calendar.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "128": "icons/icon128.png"
  }
}
